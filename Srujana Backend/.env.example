# =============================================================================
# .env.example — commit this file. Never commit the real .env.local.
# =============================================================================
# HOW THIS FILE IS USED
#   - Next.js reads .env.local at BUILD time. That's where NEXT_PUBLIC_SITE_URL
#     needs to live so it gets baked into the static export.
#   - The Cloudflare Pages Function (/functions/api/contact.ts) does NOT read
#     these vars. It reads from the Worker environment, which locally comes from
#     .dev.vars (see .dev.vars.example) and in production from the Cloudflare
#     Pages dashboard → Settings → Environment variables.
#   - Copy this to .env.local for local Next.js build/dev.
# =============================================================================

# Public site origin. Baked into <link rel="canonical">, sitemap.xml, OG tags.
# NEXT_PUBLIC_ prefix means this ships to the browser — that is intentional here.
# It is NOT a secret; it's just the public URL of the site.
NEXT_PUBLIC_SITE_URL=https://accurith.com

# -----------------------------------------------------------------------------
# The variables below are ONLY needed if you also want to build the site with
# access to backend config. They do not need NEXT_PUBLIC_ prefix and MUST NOT
# have it — see .dev.vars.example for the runtime-side truth.
# -----------------------------------------------------------------------------
