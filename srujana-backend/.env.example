# =============================================================================
# .env.example — commit this file. Copy to .env.local for real values.
# .env.local is git-ignored. Never commit real values to any .env* file.
#
# Locally: Next.js and Prisma both read .env.local automatically.
# On Railway: paste each variable into the service's Variables tab. DATABASE_URL
# is auto-injected by the Postgres plugin — do not paste it manually there.
# =============================================================================

# --- Database ---------------------------------------------------------------
# Postgres connection string. On Railway this is provided by the Postgres
# plugin as ${{Postgres.DATABASE_URL}} — reference it, don't paste the raw
# URL. Locally, use the docker-compose Postgres (see docker-compose.yml):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5433/accurith
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/accurith

# --- Site -------------------------------------------------------------------
# Public site origin. Baked into <link rel="canonical">, sitemap.xml, OG tags.
# NEXT_PUBLIC_ prefix means this ships to the browser — that is fine here,
# the URL is public. Do NOT use NEXT_PUBLIC_ on anything below.
NEXT_PUBLIC_SITE_URL=https://accurith.com

# --- CORS -------------------------------------------------------------------
# Production origin of Varsha's frontend (Cloudflare Pages). Used by
# src/lib/cors.ts to allow her prod app to call /api/contact,
# /api/early-access, /api/careers/*. http://localhost:3000 is always allowed
# in addition to this — that's her dev origin, hardcoded so local always works.
# Leave blank in dev, set on Railway. Never use "*".
FRONTEND_ORIGIN=https://accurith.com

# --- SMTP (server-side only, never NEXT_PUBLIC_) ----------------------------
# Provider-agnostic. Any host that speaks SMTP over TLS works.
# Examples:
#   smtp.gmail.com               (Google Workspace, requires app password)
#   smtp-mail.outlook.com        (Microsoft 365)
#   email-smtp.<region>.amazonaws.com  (AWS SES)
#   smtp.zoho.in                 (Zoho Mail, India region)
SMTP_HOST=

# 465 = implicit TLS. 587 = STARTTLS. Both supported.
# Do NOT use port 25 — most hosts (Railway included) block outbound 25.
SMTP_PORT=465

# SMTP auth — full email address of the sending mailbox.
SMTP_USER=

# For Gmail/Workspace, this MUST be an app password generated at
# https://myaccount.google.com/apppasswords (2FA required).
# The account password will not work.
SMTP_PASS=

# Where enquiries and applications land.
MAIL_TO=hello@accurith.com

# --- Why none of the SMTP or DB vars have NEXT_PUBLIC_ ----------------------
# Any variable prefixed with NEXT_PUBLIC_ is inlined into the browser bundle
# at build time. Prefixing SMTP_PASS or DATABASE_URL would leak them to
# every visitor. Everything above (except NEXT_PUBLIC_SITE_URL) is used
# server-side only — inside API route handlers and the mail sender.
